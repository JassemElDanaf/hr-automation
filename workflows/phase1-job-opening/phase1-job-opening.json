    {
      "parameters": {
        "jsCode": "// Merge point — check for errors from any path, then prepare DB insert\nconst item = $input.first().json;\n\nif (item.error) {\n  return [{ json: item }];\n}\n\n// Final validation before DB write\nif (!item.job_description || item.job_description.trim().length < 10) {\n  return [{ json: { error: true, message: 'Job description is empty after processing', status: 400 } }];\n}\n\nreturn [{ json: {\n  error: false,\n  job_title: item.job_title,\n  department: item.department,\n  employment_type: item.employment_type,\n  seniority_level: item.seniority_level,\n  location_type: item.location_type,\n  reporting_to: item.reporting_to || null,\n  description_source_type: item.description_source_type,\n  job_description: item.job_description,\n  uploaded_file_name: item.uploaded_file_name || null,\n  status: item.status || 'draft',\n  is_active: item.is_active !== undefined ? item.is_active : true,\n  ai_fallback: item.ai_fallback || false\n} }];"
      },

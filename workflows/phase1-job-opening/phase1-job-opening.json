    {
      "parameters": {
        "jsCode": "// Parse optional query parameters for filtering\nconst query = $input.first().json.query || {};\n\nlet whereClauses = [];\nlet params = [];\nlet paramIndex = 1;\n\nif (query.is_active !== undefined) {\n  whereClauses.push(`is_active = $${paramIndex}`);\n  params.push(query.is_active === 'true');\n  paramIndex++;\n}\n\nif (query.status) {\n  whereClauses.push(`status = $${paramIndex}`);\n  params.push(query.status);\n  paramIndex++;\n}\n\nif (query.department) {\n  whereClauses.push(`department ILIKE $${paramIndex}`);\n  params.push(`%${query.department}%`);\n  paramIndex++;\n}\n\nconst whereSQL = whereClauses.length > 0 ? 'WHERE ' + whereClauses.join(' AND ') : '';\nconst limit = Math.min(parseInt(query.limit) || 50, 100);\nconst offset = Math.max(parseInt(query.offset) || 0, 0);\n\nreturn [{ json: {\n  query: `SELECT id, job_title, department, employment_type, seniority_level, location_type, reporting_to, description_source_type, status, is_active, created_at, updated_at FROM job_openings ${whereSQL} ORDER BY created_at DESC LIMIT ${limit} OFFSET ${offset}`,\n  countQuery: `SELECT COUNT(*) as total FROM job_openings ${whereSQL}`,\n  params: params\n} }];"
      },

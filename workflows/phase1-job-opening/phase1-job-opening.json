    {
      "parameters": {
        "jsCode": "// Validate required input fields\nconst body = $input.first().json.body || $input.first().json;\n\nconst required = ['job_title', 'department', 'employment_type', 'seniority_level', 'location_type', 'description_source'];\nconst missing = required.filter(f => !body[f] || String(body[f]).trim() === '');\n\nif (missing.length > 0) {\n  return [{ json: { error: true, message: `Missing required fields: ${missing.join(', ')}`, status: 400 } }];\n}\n\nconst validEmploymentTypes = ['Full-time', 'Part-time', 'Contract', 'Internship', 'Temporary'];\nif (!validEmploymentTypes.includes(body.employment_type)) {\n  return [{ json: { error: true, message: `Invalid employment_type. Must be one of: ${validEmploymentTypes.join(', ')}`, status: 400 } }];\n}\n\nconst validSeniority = ['Junior', 'Mid-level', 'Senior', 'Lead', 'Manager', 'Director', 'VP', 'C-level'];\nif (!validSeniority.includes(body.seniority_level)) {\n  return [{ json: { error: true, message: `Invalid seniority_level. Must be one of: ${validSeniority.join(', ')}`, status: 400 } }];\n}\n\nconst validLocation = ['On-site', 'Remote', 'Hybrid'];\nif (!validLocation.includes(body.location_type)) {\n  return [{ json: { error: true, message: `Invalid location_type. Must be one of: ${validLocation.join(', ')}`, status: 400 } }];\n}\n\nconst validSources = ['ai_generate', 'manual', 'file_upload'];\nif (!validSources.includes(body.description_source)) {\n  return [{ json: { error: true, message: `Invalid description_source. Must be one of: ${validSources.join(', ')}`, status: 400 } }];\n}\n\n// For manual: require job_description\nif (body.description_source === 'manual' && (!body.job_description || String(body.job_description).trim().length < 20)) {\n  return [{ json: { error: true, message: 'Manual description must be at least 20 characters', status: 400 } }];\n}\n\nreturn [{ json: { ...body, error: false } }];"
      },

        "options": {
          "responseCode": 200
        }
      },
      "id": "resp-dash-sl",
      "name": "DashSl - Response",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [700, 500]
    }
  ],

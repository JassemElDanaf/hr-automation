      "typeVersion": 2,
      "position": [
        250,
        500
      ],
      "webhookId": "dashboard-shortlist"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT s.id, s.candidate_id, s.job_opening_id, s.status, s.shortlisted_at, s.updated_at, s.notes, c.candidate_name, c.email FROM shortlist s INNER JOIN candidates c ON c.id = s.candidate_id ORDER BY s.updated_at DESC",
        "options": {}

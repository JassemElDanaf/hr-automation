        250,
        700
      ],
      "webhookId": "talent-pool"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT c.id, c.candidate_name, c.email, c.submitted_at, c.cv_text, c.job_opening_id, j.job_title, j.department, e.overall_score, s.status AS shortlist_status, (c.cv_file_data IS NOT NULL AND length(c.cv_file_data) > 10) AS cv_file_available FROM candidates c JOIN job_openings j ON j.id = c.job_opening_id LEFT JOIN evaluations e ON e.candidate_id = c.id AND e.job_opening_id = c.job_opening_id LEFT JOIN shortlist s ON s.candidate_id = c.id AND s.job_opening_id = c.job_opening_id ORDER BY c.submitted_at DESC",
        "options": {}

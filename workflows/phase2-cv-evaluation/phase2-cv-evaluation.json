    {
      "parameters": {
        "jsCode": "const scores = $('Eval - Score Candidates').all();\nconst candidates = scores.map(s => ({\n  candidate_id: s.json.candidate_id,\n  candidate_name: s.json.candidate_name,\n  overall_score: s.json.overall_score,\n  skills_score: s.json.skills_score,\n  experience_score: s.json.experience_score,\n  education_score: s.json.education_score,\n  reasoning: s.json.reasoning,\n  strengths: s.json.strengths,\n  weaknesses: s.json.weaknesses\n}));\ncandidates.sort((a, b) => b.overall_score - a.overall_score);\nreturn [{ json: { evaluated: candidates.length, results: candidates } }];"
      },

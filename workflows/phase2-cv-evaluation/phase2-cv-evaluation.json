      "id": "fetch-job-candidates",
      "name": "Eval - Fetch Job & Candidates",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        920,
        920
      ],
      "alwaysOutputData": true,
      "credentials": {
        "postgres": {
          "id": "1",
          "name": "HR PostgreSQL"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst first = items[0]?.json || {};\nif (!first.job_id) {\n  return [{ json: { error: true, message: 'Job not found, inactive, or no unevaluated candidates' } }];\n}\nconst valNode = $('Eval - Validate Input').first().json;\nconst wSkills = Math.round((valNode.skills_weight || 0.4) * 100);\nconst wExp = Math.round((valNode.experience_weight || 0.35) * 100);\nconst wEdu = Math.round((valNode.education_weight || 0.25) * 100);\nconst criteriaText = valNode.criteria_text || '';\nconst jobDesc = criteriaText || first.job_description || '';\nconst results = [];\nfor (const item of items) {\n  const cvText = (item.json.cv_text || '').substring(0, 3000);\n  const prompt = `You are a professional HR evaluator. Analyze the following CV against the job requirements and provide a detailed evaluation.\n\nJOB TITLE: ${first.job_title}\nDEPARTMENT: ${first.department || 'N/A'}\nSENIORITY: ${first.seniority_level || 'N/A'}\nJOB DESCRIPTION / CRITERIA:\n${jobDesc.substring(0, 1500)}\n\nSCORING WEIGHTS: Skills ${wSkills}%, Experience ${wExp}%, Education ${wEdu}%\n\nCANDIDATE CV:\n${cvText}\n\nEvaluate this candidate thoroughly. Consider their skills match, years and relevance of experience, education credentials, and overall fit.\n\nYou MUST respond with ONLY a valid JSON object in this exact format (no other text before or after):\n{\"skills_score\": <number 0-10>, \"experience_score\": <number 0-10>, \"education_score\": <number 0-10>, \"strengths\": [\"strength1\", \"strength2\", \"strength3\"], \"weaknesses\": [\"weakness1\", \"weakness2\"], \"reasoning\": \"Brief explanation of your evaluation\"}`;\n  results.push({ json: {\n    error: false,\n    candidate_id: item.json.candidate_id,\n    candidate_name: item.json.candidate_name,\n    job_opening_id: item.json.job_id,\n    prompt: prompt,\n    requestBody: JSON.stringify({model: 'qwen3:4b', prompt: prompt, stream: false, options: {num_predict: 8000, num_ctx: 4096, temperature: 0.4}}),\n    wSkills: wSkills / 100,\n    wExp: wExp / 100,\n    wEdu: wEdu / 100\n  }});\n}\nreturn results;"
      },
      "id": "prepare-prompts",
      "name": "Eval - Prepare Prompts",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1140,
        920
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://127.0.0.1:11434/api/generate",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ $json.requestBody }}",
        "options": {
          "timeout": 300000
        }
      },
      "id": "call-ollama",
      "name": "Eval - Call Ollama",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1360,
        920
      ],
      "onError": "continueRegularOutput",
      "retryOnFail": false
    },
    {
      "parameters": {
        "jsCode": "// Guard: Prepare Prompts may have emitted a no-candidates marker (error:true, no candidate_id).\n// In that case the HTTP node will have returned an empty/error response that Score Candidates\n// would otherwise fall back to 5/5/5 and try to INSERT with null candidate_id. Route cleanly.\nconst promptItemsCheck = $('Eval - Prepare Prompts').all();\nconst validPrompts = promptItemsCheck.filter(p => p?.json?.candidate_id);\nif (validPrompts.length === 0) {\n  return [{ json: { error: true, message: 'No unevaluated candidates to score' } }];\n}\nconst items = $input.all();\nconst promptItems = $('Eval - Prepare Prompts').all();\nconst results = [];\nfor (let i = 0; i < items.length; i++) {\n  const raw = items[i].json;\n  const meta = promptItems[i]?.json || {};\n  const wSkills = meta.wSkills || 0.4;\n  const wExp = meta.wExp || 0.35;\n  const wEdu = meta.wEdu || 0.25;\n  let aiText = (raw.response || '').trim();\n  // If response is empty, check thinking field for content\n  if (!aiText && raw.thinking) {\n    // Try to extract JSON from thinking\n    const thinkMatch = raw.thinking.match(/\\{[\\s\\S]*?\"skills_score\"[\\s\\S]*?\\}/);\n    if (thinkMatch) aiText = thinkMatch[0];\n  }\n  // Extract JSON from the response\n  let parsed = null;\n  try {\n    // Try direct parse\n    parsed = JSON.parse(aiText);\n  } catch(e) {\n    // Try to find JSON in the text\n    const jsonMatch = aiText.match(/\\{[\\s\\S]*?\"skills_score\"[\\s\\S]*?\\}/);\n    if (jsonMatch) {\n      try { parsed = JSON.parse(jsonMatch[0]); } catch(e2) {}\n    }\n  }\n  let skillsScore, expScore, eduScore, strengths, weaknesses, reasoning;\n  if (parsed && typeof parsed.skills_score === 'number') {\n    skillsScore = Math.min(10, Math.max(0, Math.round(parsed.skills_score * 10) / 10));\n    expScore = Math.min(10, Math.max(0, Math.round(parsed.experience_score * 10) / 10));\n    eduScore = Math.min(10, Math.max(0, Math.round(parsed.education_score * 10) / 10));\n    strengths = Array.isArray(parsed.strengths) ? parsed.strengths.join('; ') : (parsed.strengths || '');\n    weaknesses = Array.isArray(parsed.weaknesses) ? parsed.weaknesses.join('; ') : (parsed.weaknesses || '');\n    reasoning = parsed.reasoning || 'AI evaluation by Qwen3';\n  } else {\n    // Fallback: basic keyword scoring\n    skillsScore = 5; expScore = 5; eduScore = 5;\n    strengths = 'AI evaluation could not be fully parsed';\n    weaknesses = 'Re-evaluate recommended';\n    reasoning = 'AI evaluation could not produce structured scores. Please re-evaluate.';\n  }\n  const overall = Math.round((skillsScore * wSkills + expScore * wExp + eduScore * wEdu) * 10) / 10;\n  results.push({ json: {\n    error: false,\n    candidate_id: meta.candidate_id,\n    candidate_name: meta.candidate_name,\n    job_opening_id: meta.job_opening_id,\n    overall_score: overall,\n    skills_score: skillsScore,\n    experience_score: expScore,\n    education_score: eduScore,\n    reasoning: reasoning,\n    strengths: strengths,\n    weaknesses: weaknesses,\n    sql: 'INSERT INTO evaluations (candidate_id, job_opening_id, overall_score, skills_score, experience_score, education_score, reasoning, strengths, weaknesses) VALUES ($1, $2, $3, $4, $5, $6, $7, $8, $9) RETURNING *',\n    params: [meta.candidate_id, meta.job_opening_id, overall, skillsScore, expScore, eduScore, reasoning, strengths, weaknesses]\n  }});\n}\nreturn results;"
      },

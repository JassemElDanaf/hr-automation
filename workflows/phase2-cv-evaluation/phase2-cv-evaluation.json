    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json || {};\nconst jobId = parseInt(body.job_opening_id);\nif (!jobId || isNaN(jobId) || jobId < 1) {\n  return [{ json: { error: true, message: 'Valid job_opening_id is required', status: 400 } }];\n}\nlet sql = 'SELECT j.id as job_id, j.job_title, j.job_description, j.department, j.seniority_level, c.id as candidate_id, c.candidate_name, c.email, c.cv_text FROM job_openings j INNER JOIN candidates c ON c.job_opening_id = j.id LEFT JOIN evaluations e ON e.candidate_id = c.id AND e.job_opening_id = j.id WHERE j.id = $1 AND j.is_active = true AND e.id IS NULL';\nlet params = [jobId];\nconst candId = parseInt(body.candidate_id);\nif (candId && !isNaN(candId) && candId > 0) {\n  sql += ' AND c.id = $2';\n  params.push(candId);\n}\nconst sk = parseFloat(body.skills_weight) || 40;\nconst ex = parseFloat(body.experience_weight) || 35;\nconst ed = parseFloat(body.education_weight) || 25;\nconst criteriaText = (body.criteria_text || '').trim();\nreturn [{ json: { error: false, jobId: jobId, sql: sql, params: params, skills_weight: sk / 100, experience_weight: ex / 100, education_weight: ed / 100, criteria_text: criteriaText } }];"
      },

    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json || {};\nconst jobTitle = (body.job_title || '').trim();\nconst department = (body.department || '').trim();\nconst seniority = (body.seniority_level || '').trim();\nconst employment = (body.employment_type || '').trim();\nconst jobDescription = (body.job_description || '').trim();\nif (!jobTitle) {\n  return [{ json: { error: true, message: 'job_title required', status: 400 } }];\n}\nconst prompt = `You are an HR expert. Based on the job details below, generate a structured list of evaluation criteria for screening CVs. Output 5-8 specific, measurable criteria grouped under three categories: SKILLS, EXPERIENCE, and EDUCATION. Be concise and specific to the role.\n\nJob Title: ${jobTitle}\n${department ? 'Department: ' + department : ''}\n${seniority ? 'Seniority: ' + seniority : ''}\n${employment ? 'Employment Type: ' + employment : ''}\n${jobDescription ? '\\nJob Description:\\n' + jobDescription.substring(0, 2000) : ''}\n\nOutput format (plain text, no markdown):\n\nSKILLS:\n- criterion 1\n- criterion 2\n...\n\nEXPERIENCE:\n- criterion 1\n- criterion 2\n...\n\nEDUCATION:\n- criterion 1\n- criterion 2\n...\n\nGenerate the criteria now:`;\nreturn [{ json: { error: false, prompt: prompt, requestBody: JSON.stringify({ model: 'qwen3:4b', prompt: prompt, stream: false, options: { num_predict: 4000, num_ctx: 4096, temperature: 0.4 } }) } }];"

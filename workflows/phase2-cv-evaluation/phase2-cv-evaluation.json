        "jsCode": "const body = $input.first().json.body || $input.first().json || {};\nconst errors = [];\nif (!body.job_opening_id || isNaN(parseInt(body.job_opening_id))) errors.push('job_opening_id (number) is required');\nif (!body.candidate_name || !body.candidate_name.trim()) errors.push('candidate_name is required');\nif (!body.cv_text || !body.cv_text.trim()) errors.push('cv_text is required');\nelse if (body.cv_text.trim().length < 20) errors.push('cv_text must be at least 20 characters');\n\nif (errors.length > 0) {\n  return [{ json: { error: true, message: 'Validation failed: ' + errors.join(', '), status: 400 } }];\n}\n\nconst jobId = parseInt(body.job_opening_id);\nreturn [{ json: {\n  error: false,\n  sql: 'INSERT INTO candidates (job_opening_id, candidate_name, email, cv_text, cv_file_name) SELECT $1, $2, $3, $4, $5 WHERE EXISTS (SELECT 1 FROM job_openings WHERE id = $1 AND is_active = true) RETURNING *',\n  params: [jobId, body.candidate_name.trim(), (body.email || '').trim() || null, body.cv_text.trim(), (body.cv_file_name || '').trim() || null]\n} }];"

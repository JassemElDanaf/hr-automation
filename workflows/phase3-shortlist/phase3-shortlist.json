      ],
      "webhookId": "add-to-shortlist"
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json || {};\nconst candidateId = parseInt(body.candidate_id);\nconst jobId = parseInt(body.job_opening_id);\nif (!candidateId || isNaN(candidateId) || !jobId || isNaN(jobId)) {\n  return [{ json: { error: true, message: 'Valid candidate_id and job_opening_id required', status: 400 } }];\n}\nconst notes = (body.notes || '').trim();\nreturn [{ json: { error: false, sql: 'INSERT INTO shortlist (candidate_id, job_opening_id, notes) VALUES ($1, $2, $3) ON CONFLICT (candidate_id, job_opening_id) DO UPDATE SET status = \\'shortlisted\\', notes = EXCLUDED.notes, updated_at = NOW() RETURNING *', params: [candidateId, jobId, notes] } }];"
      },

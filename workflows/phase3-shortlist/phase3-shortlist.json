    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json || {};\nconst id = parseInt(body.id);\nconst status = (body.status || '').trim().toLowerCase();\nconst validStatuses = ['shortlisted','interviewed','hired','rejected'];\nif (!id || isNaN(id)) {\n  return [{ json: { error: true, message: 'Valid shortlist id required', status: 400 } }];\n}\nif (!validStatuses.includes(status)) {\n  return [{ json: { error: true, message: 'Status must be: ' + validStatuses.join(', '), status: 400 } }];\n}\nconst notes = body.notes !== undefined ? body.notes : null;\nlet sql = 'UPDATE shortlist SET status = $1, updated_at = NOW()';\nlet params = [status];\nif (notes !== null) {\n  sql += ', notes = $3';\n  params.push(id);\n  params.push(notes);\n  sql += ' WHERE id = $2 RETURNING *';\n} else {\n  params.push(id);\n  sql += ' WHERE id = $2 RETURNING *';\n}\nreturn [{ json: { error: false, sql: sql, params: params } }];"
      },

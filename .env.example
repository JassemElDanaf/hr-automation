# Diyar HR Automation — environment template
# Copy this file to .env and fill in real values. .env is gitignored.
#
# Loaded by start.sh on every launch. Restart services after editing.

# --- PostgreSQL ---
# Used by n8n's "HR PostgreSQL" credential and by scripts/setup-db.sh.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=hr_admin
POSTGRES_PASSWORD=hr_pass
POSTGRES_DB=hr_automation

# --- Ollama (local AI) ---
# Used by workflows that call Ollama over HTTP.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b

# --- n8n ---
# The port n8n listens on. Also embedded in the frontend's API constant.
N8N_PORT=5678
# Set to true for a personal dev setup to skip the login screen.
N8N_USER_MANAGEMENT_DISABLED=true

# --- SMTP (Gmail app password, or any SMTP provider) ---
# Required for Phase 5 to actually send emails.
# If SMTP_HOST is empty, the sidecar will "log only" — rows still land in email_log
# with status='logged' but nothing is sent.
#
# For Gmail:
#   1. Enable 2-Step Verification on the Google account
#   2. Generate an app password at https://myaccount.google.com/apppasswords
#   3. Put the 16-character password here as SMTP_PASS (no spaces)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-address@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM="Diyar HR <your-address@gmail.com>"

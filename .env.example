# Diyar HR — environment template
# Copy this file to .env and fill in real values. .env is gitignored.
#
# For local Windows dev: loaded by start.sh on every launch.
# For Docker:            docker-compose.yml reads this file automatically.
#                        Run: cp .env.example .env  then edit .env

# --- PostgreSQL ---
# Used by n8n's "HR PostgreSQL" credential and by scripts/setup-db.sh.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=hr_admin
POSTGRES_PASSWORD=hr_pass
POSTGRES_DB=hr_automation

# --- Ollama (local AI) ---
# Used by workflows that call Ollama over HTTP.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b
#
# Docker mode — which Ollama does n8n call?
#   ollama                → the bundled Docker Ollama service (DEFAULT; always-on, fully self-contained)
#   host.docker.internal  → an Ollama installed on the HOST instead (then stop/disable the Docker one)
OLLAMA_DOCKER_HOST=ollama
# Where the Docker Ollama service stores its models. Keep this on the D: drive
# so model files never land on C: or E:. qwen3:4b ≈ 2.5 GB. Docker creates the
# folder if it doesn't exist. (On Linux/macOS use a path like ./ollama-data.)
OLLAMA_DATA_DIR=D:/DiyarDocker/ollama

# --- n8n ---
# The port n8n listens on. Also embedded in the frontend's API constant.
N8N_PORT=5678
# Set to true for a personal dev setup to skip the login screen.
N8N_USER_MANAGEMENT_DISABLED=true
# n8n data directory (workflows, credentials, executions). Lives on D:\ to save C:\ space.
N8N_USER_FOLDER=D:\n8n

# --- SMTP (Gmail app password, or any SMTP provider) ---
# Required for Phase 5 to actually send emails.
# If SMTP_HOST is empty, the sidecar will "log only" — rows still land in email_log
# with status='logged' but nothing is sent.
#
# For Gmail:
#   1. Enable 2-Step Verification on the Google account
#   2. Generate an app password at https://myaccount.google.com/apppasswords
#   3. Put the 16-character password here as SMTP_PASS (no spaces)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-address@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM="Diyar HR <your-address@gmail.com>"

# --- IMAP (inbound replies) ---
# Pulled by scripts/imap_server.py every IMAP_POLL_SEC. Same Gmail App Password
# used for SMTP works here. Without IMAP_HOST, the sidecar runs but skips polling.
# Replies land in email_log with direction='inbound', threaded to the original
# outbound row by Message-ID matching.
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your-address@gmail.com
IMAP_PASS=your_app_password_here
IMAP_FOLDER=INBOX
IMAP_POLL_SEC=60

# n8n REST API login (used by docs/runbook.md workflow-activation commands)
N8N_REST_USER=you@example.com
N8N_REST_PASSWORD=changeme
